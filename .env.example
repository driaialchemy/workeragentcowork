# ──────────────────────────────────────────────────────────────────────────────
# .env.example
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# OpenAI API key (required)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# OpenAI model to use. The default is cost-conscious and works for this app.
OPENAI_MODEL=gpt-4o-mini

# Maximum articles to collect from each source. Keeps weekly runs predictable.
MAX_ARTICLES_PER_SOURCE=2

# Optional global cap. Use 0 for no global cap, so every source is searched.
MAX_TOTAL_ARTICLES=0

# ── Email settings (optional — leave blank to skip emailing) ──────────────────

# Outgoing mail server
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Your sending Gmail address
SMTP_USER=you@gmail.com

# Gmail App Password (NOT your regular password)
# Generate one at: https://myaccount.google.com/apppasswords
SMTP_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Default recipient for the finished briefing report
EMAIL_TO=recipient@example.com
